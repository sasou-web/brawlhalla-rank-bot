# Copie ce fichier en ".env" et remplis les valeurs. Ne commit JAMAIS le .env.
# L'API Brawlhalla v1 est publique : AUCUNE cle API n'est necessaire.

# Token de ton bot Discord (Developer Portal > Bot > Reset Token)
DISCORD_TOKEN=

# Application/Client ID du bot (Developer Portal > General Information > Application ID)
CLIENT_ID=

# ID de ton serveur Discord (clic droit sur l'icone du serveur > Copier l'identifiant)
GUILD_ID=

# File de validation par le staff (recommande). Laisse vide pour une liaison directe sans modo.
# REVIEW_CHANNEL_ID : salon ou arrivent les demandes a valider (clic droit sur le salon > Copier l'identifiant).
# REVIEWER_ROLE_ID  : role autorise a valider/refuser (sinon, permission "Gerer le serveur" requise).
REVIEW_CHANNEL_ID=
REVIEWER_ROLE_ID=

# Intervalle de rafraichissement automatique des roles, en minutes (defaut 60)
REFRESH_INTERVAL_MINUTES=60

# ---------- Index local du leaderboard (recherche /lier /stats instantanee) ----------
# Le bot synchronise les meilleurs joueurs classes 1v1 dans une base locale, ce qui rend
# la recherche par pseudo INSTANTANEE et resiliente aux pannes (502) de l'API officielle.
# Nombre de pages a synchroniser (50 joueurs/page). 500 = top ~25 000. 0 = desactive.
LEADERBOARD_SYNC_PAGES=500
# Frequence de la synchro en minutes (defaut 180 = 3h).
LEADERBOARD_SYNC_INTERVAL_MINUTES=180

# ---------- Dashboard web (optionnel) ----------
# Le dashboard ne demarre QUE si CLIENT_SECRET, PUBLIC_URL et SESSION_SECRET sont remplis.
# CLIENT_SECRET : Developer Portal > ton app > OAuth2 > Client Secret.
CLIENT_SECRET=
# URL publique d'acces au dashboard (sans / final). Ex: http://91.98.17.48:3000
# Ajoute "<PUBLIC_URL>/callback" dans Developer Portal > OAuth2 > Redirects.
PUBLIC_URL=
# Secret pour signer les sessions (mets une longue chaine aleatoire).
SESSION_SECRET=
# Port d'ecoute du dashboard (defaut 3000).
WEB_PORT=3000
